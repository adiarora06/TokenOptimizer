    "test:api": "node tests/api-endpoints.test.cjs",
    "test:extension": "node extensions/gemini-token-optimizer/tests/sidepanel-logic.test.cjs && node extensions/gemini-token-optimizer/tests/content-gemini.test.cjs && node extensions/gemini-token-optimizer/tests/content-chatgpt.test.cjs"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.45.0",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "zod": "^4.4.3"
  }
}
