# Copy this file to .env.local and add rotated keys.
# Do not put real keys in the frontend HTML.

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: enables estimated dollar cost in the usage strip.
GROQ_INPUT_COST_PER_MILLION=
GROQ_OUTPUT_COST_PER_MILLION=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_INPUT_COST_PER_MILLION=
OPENAI_OUTPUT_COST_PER_MILLION=

# Anonymous safety limits. Production firewall limits should also be configured.
TOKEN_OPTIMIZER_MAX_INPUT_CHARS=80000
TOKEN_OPTIMIZER_RATE_MAX=20
TOKEN_OPTIMIZER_RATE_WINDOW_MS=60000

# Leave disabled in production. Local development already permits localhost endpoints.
TOKEN_OPTIMIZER_ALLOW_PRIVATE_ENDPOINTS=0
